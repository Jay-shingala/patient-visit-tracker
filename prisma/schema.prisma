generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Clinician {
  id        String   @id @default(cuid())
  name      String
  specialty String?
  createdAt DateTime @default(now())
  visits    Visit[]

  @@map("clinicians")
}

model Patient {
  id          String    @id @default(cuid())
  name        String
  email       String?   @unique
  dateOfBirth DateTime?
  createdAt   DateTime  @default(now())
  visits      Visit[]

  @@map("patients")
}

model Visit {
  id          String    @id @default(cuid())
  clinicianId String
  patientId   String
  visitedAt   DateTime  @default(now())
  notes       String?
  createdAt   DateTime  @default(now())
  clinician   Clinician @relation(fields: [clinicianId], references: [id], onDelete: Cascade)
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([visitedAt(sort: Desc)])
  @@index([clinicianId, visitedAt(sort: Desc)])
  @@index([patientId, visitedAt(sort: Desc)])
  @@map("visits")
}
